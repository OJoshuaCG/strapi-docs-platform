# ══════════════════════════════════════════════════════════════════════════════
# backend/.env  —  Docker Compose environment
# Copy this file to .env and fill in all values before running docker compose.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────────────────────
# Two modes depending on which compose file(s) you use:
#
#   External DB (default):
#     docker compose up
#     Set DATABASE_HOST to host.docker.internal (local machine) or a remote hostname.
#
#   Containerized MariaDB:
#     docker compose -f docker-compose.yml -f docker-compose.db.yml up
#     DATABASE_HOST is overridden automatically to the mariadb container.
#     DATABASE_ROOT_PASSWORD is required in this mode.
#
# Supported clients: mysql | postgres | sqlite
DATABASE_CLIENT=mysql
DATABASE_HOST=host.docker.internal
DATABASE_PORT=3306
DATABASE_NAME=strapi_docs
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=              # Password for the DB user
DATABASE_ROOT_PASSWORD=         # Only required with docker-compose.db.yml (MariaDB container)

# ─── Strapi secrets ───────────────────────────────────────────────────────────
# Each value must be a cryptographically random string.
#
# Generate APP_KEYS (comma-separated, minimum 2):
#   node -e "const c=require('crypto');console.log([1,2].map(()=>c.randomBytes(32).toString('base64')).join(','))"
#
# Generate the rest (one per variable):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

APP_KEYS=
API_TOKEN_SALT=
ADMIN_JWT_SECRET=
JWT_SECRET=
TRANSFER_TOKEN_SALT=
ENCRYPTION_KEY=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origin allowed to call the Strapi API. No wildcard.
FRONTEND_URL=http://localhost:5173

# ─── Wasabi (S3-compatible storage) ───────────────────────────────────────────
# Leave blank to use local disk storage (public/uploads/) during development.
# Fill in to route Media Library uploads to Wasabi.
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
WASABI_BUCKET=
WASABI_REGION=us-east-1
WASABI_ENDPOINT=https://s3.wasabisys.com
# Prefix (folder) inside the bucket where uploads will be stored.
WASABI_UPLOAD_PREFIX=cms

# ─── Frontend (SvelteKit) ─────────────────────────────────────────────────────
# URL where Strapi is publicly accessible (must be reachable from the browser).
# Used as the VITE_STRAPI_URL build arg for the frontend Docker image.
VITE_STRAPI_URL=http://localhost:1337

# ─── Meilisearch ──────────────────────────────────────────────────────────────
# Service starts in Phase 1; plugin integration is Phase 2.
# Choose a strong random key — required even in dev mode.
MEILISEARCH_MASTER_KEY=
# development | production
MEILI_ENV=development

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used for admin invitations, password recovery, etc.
# Works with any SMTP provider: Gmail (App Password), Outlook, Sendgrid, Mailgun, Resend, etc.
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@tudominio.com
SMTP_PASS=
EMAIL_FROM="Doc Platform <notificaciones@tudominio.com>"
EMAIL_REPLY_TO=admin@tudominio.com

# ─── Preview ──────────────────────────────────────────────────────────────────
# Shared secret for Live Preview feature (must match frontend PREVIEW_SECRET)
PREVIEW_SECRET=
