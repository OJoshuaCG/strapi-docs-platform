{
  "kind": "collectionType",
  "collectionName": "global_settings",
  "info": {
    "singularName": "global-setting",
    "pluralName": "global-settings",
    "displayName": "Global Settings",
    "description": "Site-wide design tokens, typography, spacing, and theme configuration"
  },
  "options": {
    "draftAndPublish": false,
    "comment": ""
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true,
      "default": "Documentation Portal"
    },
    "siteDescription": {
      "type": "text",
      "required": false
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "sidebarLogo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "headerLogoSize": {
      "type": "enumeration",
      "enum": ["sm", "md", "lg", "xl"],
      "default": "md",
      "required": false
    },
    "headerLinkText": {
      "type": "string",
      "required": false,
      "maxLength": 50
    },
    "headerLinkUrl": {
      "type": "string",
      "required": false
    },
    "ogDefaultImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "footerText": {
      "type": "string",
      "required": false
    },
    "typography": {
      "type": "component",
      "component": "theme.typography",
      "required": false
    },
    "spacing": {
      "type": "component",
      "component": "theme.spacing",
      "required": false
    },
    "colors": {
      "type": "component",
      "component": "theme.colors",
      "required": false
    },
    "layout": {
      "type": "component",
      "component": "theme.layout",
      "required": false
    }
  }
}
