# ══════════════════════════════════════════════════════════════════════════════
# frontend/.env  —  SvelteKit environment
# Vite exposes variables prefixed with VITE_ to browser code.
# ══════════════════════════════════════════════════════════════════════════════

# URL of the Strapi CMS API (no trailing slash).
# Baked into the JS bundle at build time — used by the browser for client-side requests.
# In Docker Compose build args: http://localhost:1337 (reachable from the user's browser)
# In local dev (Strapi running on host):    http://localhost:1337
VITE_STRAPI_URL=http://localhost:1337

# Internal URL for SSR → Strapi requests inside Docker.
# Set this at runtime (not build time) so Node.js can reach Strapi via the
# internal Docker network. Leave empty for local dev outside Docker.
# Example: STRAPI_INTERNAL_URL=http://strapi:1337
STRAPI_INTERNAL_URL=

# Shared secret for Live Preview feature (must match backend PREVIEW_SECRET)
PREVIEW_SECRET=

# Host/port for the SvelteKit dev server (used by vite dev --host)
HOST=0.0.0.0
PORT=5173
