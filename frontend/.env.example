# ══════════════════════════════════════════════════════════════════════════════
# frontend/.env  —  SvelteKit environment
# Vite exposes variables prefixed with VITE_ to browser code.
# ══════════════════════════════════════════════════════════════════════════════

# URL of the Strapi CMS API (no trailing slash).
# In Docker Compose, use the service name:  http://strapi:1337
# In local dev (Strapi running on host):    http://localhost:1337
VITE_STRAPI_URL=http://localhost:1337

# Host/port for the SvelteKit dev server (used by vite dev --host)
HOST=0.0.0.0
PORT=5173
